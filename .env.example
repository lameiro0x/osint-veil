# ── Anthropic / Claude ────────────────────────────────────────────────
# Tu API key de Anthropic. Solo se usa para llamar a la API de Claude.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Modelo por defecto (el spec usa sonnet-4-6; puedes subir a claude-opus-4-8).
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Proxy local ───────────────────────────────────────────────────────
# Clave que DEBES enviar como "Authorization: Bearer <PROXY_LOCAL_API_KEY>".
# Cámbiala por algo largo y aleatorio.
PROXY_LOCAL_API_KEY=change-me

# Caso por defecto si la petición no especifica case_id.
PROXY_CASE_ID=default_case

# Dónde se guardan mappings y logs (NUNCA secretos reales).
PROXY_STORAGE_PATH=./proxy_data

# Clave de cifrado del almacenamiento local (Fernet base64, 32 bytes).
# Genérala con:  python -m proxy.keygen
# Si la dejas vacía, los mappings se guardan en claro (no recomendado).
PROXY_ENCRYPTION_KEY=

# Modo por defecto: strict | balanced | reporting
PROXY_MODE=strict

# Dónde buscar los YAML de configuración por caso.
PROXY_CASES_PATH=./cases
