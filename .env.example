# ── Anthropic / Claude ────────────────────────────────────────────────
# Tu API key de Anthropic. Solo se usa para llamar a la API de Claude.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Modelo por defecto. MODO AHORRO: Haiku (≈5× más barato, ideal para pruebas).
# Sube a claude-sonnet-4-6 para máxima calidad, o claude-opus-4-8 para lo top.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Proxy local ───────────────────────────────────────────────────────
# Clave que DEBES enviar como "Authorization: Bearer <PROXY_LOCAL_API_KEY>".
# Cámbiala por algo largo y aleatorio.
PROXY_LOCAL_API_KEY=change-me

# Caso por defecto si la petición no especifica case_id.
PROXY_CASE_ID=default_case

# Dónde se guardan mappings y logs (NUNCA secretos reales).
PROXY_STORAGE_PATH=./proxy_data

# Clave de cifrado del almacenamiento local (Fernet base64, 32 bytes).
# Genérala con:  python -m proxy.keygen
# Si la dejas vacía, los mappings se guardan en claro (no recomendado).
PROXY_ENCRYPTION_KEY=

# Modo por defecto: strict | balanced | reporting
PROXY_MODE=strict

# Dónde buscar los YAML de configuración por caso.
PROXY_CASES_PATH=./cases

# ── Egress control ────────────────────────────────────────────────────
# off | warn | enforce.  En 'enforce' el OSINT autónomo se niega a arrancar
# si no se ha confirmado el lockdown de red (PROXY_EGRESS_LOCKED=1).
PROXY_EGRESS=warn
# Lo pone el despliegue tras aplicar deploy/egress_lockdown.sh (o el Docker).
PROXY_EGRESS_LOCKED=0
# Usuario sin salida a la IA bajo el que se ejecutan las herramientas EXTERNAS
# (vía sudo). Vacío = corren como el usuario del proxy (sin separación real).
PROXY_TOOLS_USER=

# ── Logging ───────────────────────────────────────────────────────────
PROXY_LOG_LEVEL=INFO
# Access log de uvicorn (rutas). 0 = desactivado (recomendado). 1 = activado.
PROXY_ACCESS_LOG=0

# ── Summarizer local (OPCIONAL) ───────────────────────────────────────
# Condensa salidas grandes ANTES de enviarlas a Claude (menos tokens = menos gasto).
# MODO AHORRO: 'ollama' activado. Necesita Ollama instalado (./setup.sh --ollama,
# o https://ollama.com + 'ollama pull llama3.2'). Es FAIL-SAFE: si Ollama no está,
# el proxy sigue igual (no rompe), solo no resume. Pon 'off' para desactivarlo.
# Opera solo sobre texto ya anonimizado (tokenizado, sin secretos).
PROXY_SUMMARIZER=ollama
PROXY_SUMMARIZER_MODEL=llama3.2
PROXY_SUMMARIZER_HOST=http://127.0.0.1:11434
PROXY_SUMMARIZER_MIN_CHARS=1500
# Trunca la entrada al resumidor: en CPU floja, resumir textos enormes es lento
# y agota el tiempo del OSINT. Con este tope el resumen es rápido y fiable.
# Si tu CPU es muy justa, usa un modelo pequeño: PROXY_SUMMARIZER_MODEL=llama3.2:1b
PROXY_SUMMARIZER_MAX_CHARS=6000
